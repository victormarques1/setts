generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String            @id @default(cuid())
  name            String
  email           String            @unique
  passwordHash    String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  workouts        Workout[]
  exerciseCatalog ExerciseCatalog[]
}

model Workout {
  id        String           @id @default(cuid())
  userId    String
  name      String
  deletedAt DateTime?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises Exercise[]
  sessions  WorkoutSession[]

  @@index([userId])
  @@index([userId, deletedAt])
}

model ExerciseCatalog {
  id              String     @id @default(cuid())
  name            String
  muscleGroup     String?
  isPublic        Boolean    @default(false)
  createdByUserId String?
  createdAt       DateTime   @default(now())
  createdBy       User?      @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  exercises       Exercise[]

  @@index([isPublic])
  @@index([createdByUserId])
  @@index([name])
}

model Exercise {
  id                String          @id @default(cuid())
  workoutId         String
  exerciseCatalogId String
  createdAt         DateTime        @default(now())
  workout           Workout         @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  catalog           ExerciseCatalog @relation(fields: [exerciseCatalogId], references: [id], onDelete: Restrict)
  setRecords        SetRecord[]

  @@unique([workoutId, exerciseCatalogId])
  @@index([workoutId])
  @@index([exerciseCatalogId])
}

model WorkoutSession {
  id          String               @id @default(cuid())
  workoutId   String
  status      WorkoutSessionStatus @default(ACTIVE)
  performedAt DateTime?
  canceledAt  DateTime?
  workout     Workout              @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  setRecords  SetRecord[]

  @@index([workoutId])
  @@index([workoutId, status])
  @@index([performedAt])
}

enum WorkoutSessionStatus {
  ACTIVE
  COMPLETED
  CANCELED
}

model SetRecord {
  id         String         @id @default(cuid())
  sessionId  String
  exerciseId String
  setNumber  Int
  weight     Float
  reps       Int
  session    WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise   Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([sessionId, exerciseId, setNumber])
  @@index([sessionId])
  @@index([exerciseId])
}
